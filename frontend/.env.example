# Credenciales del panel de administración
# Copiar este archivo como .env.local y completar con los valores reales
# El hash es SHA-256 de la contraseña (nunca guardes la contraseña en texto plano)
# Para generar un hash: echo -n "tu_contraseña" | sha256sum

VITE_ADMIN_USER=dimensionbelleza
VITE_ADMIN_PASS_HASH=
